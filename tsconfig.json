{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "scripts"
  },
  "include": ["scripts/**/*"],
  "exclude": ["node_modules", "web", "scripts/node_modules"]
}
